GOOGLE_API_KEY=lsv2_your-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your-key-here
LANGCHAIN_PROJECT=production-api
APP_ENV=development
LOG_LEVEL=INFO
RATE_LIMIT=20/minute
CACHE_TTL_SECONDS=300
MAX_RETRIES=3

# RAG / retrieval (embeddings served locally by Ollama — no API key, no quota)
EMBEDDING_MODEL=qwen3-embedding:4b
CHROMA_PERSIST_DIR=./chroma_db
MAX_RAG_RETRIES=1